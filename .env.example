# Application
APP_ENV=development
LOG_LEVEL=INFO
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRE_HOURS=24

# Database
DATABASE_URL=postgresql+psycopg2://release_intel:release_intel@localhost:5432/release_intel

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# LLM (required from M3 for live LLM; rules fallback works without keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# GitHub webhook (required from M2)
GITHUB_WEBHOOK_SECRET=dev-webhook-secret-change-me

# CORS (comma-separated origins for Next.js UI)
CORS_ORIGINS=http://localhost:3000
